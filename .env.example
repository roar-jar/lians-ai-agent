# Telegram Bot 환경변수 설정
# 이 파일을 .env 로 복사한 뒤 실제 값을 채워넣으세요.
# cp .env.example .env

# @BotFather 에서 발급받은 봇 토큰
# 형식: 123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_BOT_TOKEN=

# 메시지를 보낼 채팅 또는 채널 ID
# 개인 채팅: 양수 (예: 123456789)
# 그룹/채널: 음수 (예: -1001234567890)
# ID 확인: scripts/test-telegram.sh 실행 후 getUpdates 응답에서 확인
TELEGRAM_CHAT_ID=
